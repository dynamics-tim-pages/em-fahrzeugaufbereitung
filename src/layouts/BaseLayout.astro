---
import '@fontsource-variable/manrope';
import '@fontsource/saira-condensed/700.css';
import '@fontsource/saira-condensed/800.css';
import '@/styles/global.css';

import { site, siteMeta, uiText } from '@/data/site';
import { youtube } from '@/data/videos';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  lang?: string;
  noIndex?: boolean;
}

const {
  title = siteMeta.defaultTitle,
  description = siteMeta.description,
  canonical = new URL(Astro.url.pathname, siteMeta.baseUrl).toString(),
  image = new URL(siteMeta.ogImage, siteMeta.baseUrl).toString(),
  lang = 'de',
  noIndex = false,
} = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AutoWash',
  name: site.name,
  image,
  telephone: '+4915238485466',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    postalCode: site.address.zip,
    addressLocality: site.address.city,
    addressCountry: 'DE',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '13:30',
      closes: '18:30',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:30',
      closes: '14:00',
    },
  ],
  sameAs: [...Object.values(site.social), youtube.channelUrl],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={siteMeta.themeColor} />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={siteMeta.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] font-[family-name:var(--font-body)] text-[var(--color-text)] antialiased">
    <a
      href="#main-content"
      class="focus-ring sr-only fixed left-4 top-4 z-[70] rounded-full bg-[var(--color-green)] px-4 py-2 text-sm font-semibold text-[var(--color-bg)] focus:not-sr-only"
    >
      {uiText.skipLink}
    </a>
    <slot />
  </body>
</html>
