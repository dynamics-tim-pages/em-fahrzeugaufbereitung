---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Fahrzeugaufbereitung',
  description = 'Astro-Starter fuer eine Landingpage zur Fahrzeugaufbereitung.',
  lang = 'de',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body class="min-h-screen bg-white text-slate-900 antialiased">
    <slot />
  </body>
</html>
