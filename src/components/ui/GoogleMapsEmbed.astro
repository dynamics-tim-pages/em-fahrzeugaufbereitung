---
import { site, sectionContent, uiText } from '@/data/site';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const { map } = site;
const mapIdBase = `maps-${String(map.lat).replace('.', '-')}-${String(map.lng).replace('.', '-')}`;
const consentTitleId = `${mapIdBase}-consent-title`;
const consentDescriptionId = `${mapIdBase}-consent-description`;
---

<div
  class:list={['overflow-hidden rounded-[calc(var(--radius-card)+0.25rem)] border border-[var(--color-border)] bg-[linear-gradient(180deg,rgba(24,29,26,1),rgba(10,12,11,1))] shadow-[var(--shadow-card)]', className]}
  data-maps-embed
>
  <div
    class="relative aspect-[16/10] overflow-hidden bg-[radial-gradient(circle_at_top,rgba(91,194,54,0.16),transparent_40%),linear-gradient(180deg,rgba(17,21,19,1),rgba(10,12,11,1))]"
    data-maps-frame
    data-embed-url={map.embedUrl}
    data-share-link={map.shareLink}
    data-state="idle"
    aria-busy="false"
  >
    <!-- Hex-pattern branded placeholder (no remote requests) -->
    <div class="absolute inset-0 z-[1] hex-pattern opacity-45" data-maps-bg aria-hidden="true"></div>
    <div class="absolute inset-0 z-[2] bg-[radial-gradient(circle_at_center,rgba(91,194,54,0.18),transparent_55%)]" data-maps-bg aria-hidden="true"></div>

    <!-- Idle overlay -->
    <div
      class="absolute inset-0 z-[3] flex flex-col justify-between p-5 transition-[opacity,transform] duration-700 ease-out"
      data-maps-overlay
    >
      <div class="flex items-start justify-between gap-3">
        <span class="inline-flex rounded-full border border-[rgba(255,255,255,0.12)] bg-[rgba(10,12,11,0.68)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-green)]">
          {uiText.maps.badge}
        </span>
        <span class="rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(10,12,11,0.5)] px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
          {uiText.maps.privacyBadge}
        </span>
      </div>

      <div class="space-y-4">
        <div>
          <p class="font-[family-name:var(--font-display)] text-[clamp(1rem,2.5vw,1.5rem)] uppercase leading-none tracking-tight text-[var(--color-text)]">
            {sectionContent.contact.mapTitle}
          </p>
          <address class="mt-2 not-italic text-sm text-[var(--color-text-muted)]">
            {site.address.street}, {site.address.zip} {site.address.city}
          </address>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <button
            type="button"
            class="focus-ring inline-flex items-center gap-2 rounded-full border border-[rgba(116,224,74,0.28)] bg-[rgba(10,12,11,0.76)] px-4 py-2.5 text-sm font-semibold text-[var(--color-green)] backdrop-blur-md transition hover:-translate-y-0.5 hover:border-[rgba(116,224,74,0.42)] hover:bg-[rgba(17,21,19,0.9)]"
            data-maps-open-consent
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7Z"></path>
              <circle cx="12" cy="9" r="2.5"></circle>
            </svg>
            {uiText.maps.openLabel}
          </button>
          <a
            href={map.shareLink}
            target="_blank"
            rel="noopener noreferrer"
            class="focus-ring inline-flex items-center gap-1.5 rounded-full border border-[rgba(255,255,255,0.12)] px-4 py-2.5 text-sm font-semibold text-[var(--color-text-muted)] transition hover:-translate-y-0.5 hover:border-[rgba(255,255,255,0.24)] hover:bg-[rgba(255,255,255,0.05)] hover:text-[var(--color-text)]"
          >
            {uiText.maps.externalLabel}
            <svg aria-hidden="true" viewBox="0 0 24 24" class="size-3.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
              <polyline points="15 3 21 3 21 9"></polyline>
              <line x1="10" y1="14" x2="21" y2="3"></line>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Consent card -->
    <div
      class="pointer-events-none absolute inset-0 z-[4] flex items-end p-4 opacity-0 transition-opacity duration-500 ease-out sm:p-5"
      data-maps-consent
      aria-hidden="true"
      role="alertdialog"
      aria-labelledby={consentTitleId}
      aria-describedby={consentDescriptionId}
    >
      <div class="w-full overflow-hidden rounded-[1rem] border border-[rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(17,21,19,0.96),rgba(10,12,11,0.98))] px-4 py-4 shadow-[0_20px_50px_-28px_rgba(0,0,0,0.9)] backdrop-blur-md">
        <p id={consentTitleId} class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[rgba(116,224,74,0.82)]">
          {uiText.maps.consentTitle}
        </p>
        <p id={consentDescriptionId} class="mt-3 text-sm leading-7 text-[rgba(244,247,243,0.78)]">
          {uiText.maps.privacyNotice}
        </p>
        <div class="mt-4 flex flex-col gap-3 sm:flex-row">
          <button
            type="button"
            class="focus-ring inline-flex items-center justify-center rounded-full bg-[var(--color-green)] px-4 py-2.5 text-sm font-semibold text-[var(--color-bg)] transition hover:-translate-y-0.5 hover:bg-[var(--color-green-bright)]"
            data-maps-confirm
          >
            {uiText.maps.confirmLabel}
          </button>
          <button
            type="button"
            class="focus-ring inline-flex items-center justify-center rounded-full border border-[rgba(255,255,255,0.12)] px-4 py-2.5 text-sm font-semibold text-[var(--color-text)] transition hover:-translate-y-0.5 hover:border-[rgba(255,255,255,0.24)] hover:bg-[rgba(255,255,255,0.05)]"
            data-maps-cancel
          >
            {uiText.maps.cancelLabel}
          </button>
        </div>
      </div>
    </div>

    <!-- Loading card -->
    <div
      class="pointer-events-none absolute inset-0 z-[5] flex items-end p-4 opacity-0 transition-opacity duration-500 ease-out sm:p-5"
      data-maps-loading
      aria-hidden="true"
    >
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,12,11,0.18),rgba(10,12,11,0.82))]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(91,194,54,0.14),transparent_55%)]"></div>
      <div class="relative w-full overflow-hidden rounded-[1rem] border border-[rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(255,255,255,0.08),rgba(255,255,255,0.03))] px-4 py-3 shadow-[0_20px_50px_-28px_rgba(0,0,0,0.9)] backdrop-blur-md">
        <div class="absolute inset-0 opacity-0" data-maps-loading-sheen></div>
        <div class="relative flex items-center justify-between gap-4">
          <div class="space-y-1">
            <p class="text-[10px] font-semibold uppercase tracking-[0.22em] text-[rgba(116,224,74,0.82)]">
              {uiText.maps.loadLabel}
            </p>
            <p class="text-xs text-[rgba(244,247,243,0.72)] sm:text-sm">
              {uiText.maps.loadingHint}
            </p>
          </div>
          <span class="inline-flex items-center gap-1.5" aria-hidden="true">
            <span class="size-1.5 rounded-full bg-[rgba(116,224,74,0.72)] opacity-70" data-maps-loading-dot style="animation-delay: 0ms;"></span>
            <span class="size-1.5 rounded-full bg-[rgba(116,224,74,0.72)] opacity-70" data-maps-loading-dot style="animation-delay: 120ms;"></span>
            <span class="size-1.5 rounded-full bg-[rgba(116,224,74,0.72)] opacity-70" data-maps-loading-dot style="animation-delay: 240ms;"></span>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:inline>
  @keyframes maps-loading-sheen {
    0% { transform: translateX(-135%); opacity: 0; }
    35% { opacity: 0.4; }
    100% { transform: translateX(135%); opacity: 0; }
  }

  @keyframes maps-loading-dot {
    0%, 80%, 100% { transform: translateY(0) scale(0.92); opacity: 0.35; }
    40% { transform: translateY(-2px) scale(1); opacity: 1; }
  }

  [data-maps-frame] { isolation: isolate; }

  [data-maps-frame] iframe {
    position: absolute;
    inset: 0;
    z-index: 6;
    width: 100%;
    height: 100%;
    border: 0;
    opacity: 0;
    transition: opacity 700ms ease;
  }

  /* consent state */
  [data-maps-frame][data-state='consent'] [data-maps-overlay] {
    opacity: 0.16;
    transform: translateY(12px);
  }
  [data-maps-frame][data-state='consent'] [data-maps-consent] {
    pointer-events: auto;
    opacity: 1;
  }

  /* loading state */
  [data-maps-frame][data-state='loading'] [data-maps-bg] {
    opacity: 0.2;
  }
  [data-maps-frame][data-state='loading'] [data-maps-overlay],
  [data-maps-frame][data-state='loading'] [data-maps-consent] {
    opacity: 0;
    pointer-events: none;
  }
  [data-maps-frame][data-state='loading'] [data-maps-loading] {
    opacity: 1;
  }
  [data-maps-frame][data-state='loading'] [data-maps-loading-sheen] {
    background: linear-gradient(115deg, transparent 18%, rgba(255,255,255,0.14) 50%, transparent 82%);
    animation: maps-loading-sheen 2.8s ease-in-out infinite;
  }
  [data-maps-frame][data-state='loading'] [data-maps-loading-dot] {
    animation: maps-loading-dot 1.4s ease-in-out infinite;
  }

  /* ready state */
  [data-maps-frame][data-state='ready'] iframe { opacity: 1; }
  [data-maps-frame][data-state='ready'] [data-maps-bg],
  [data-maps-frame][data-state='ready'] [data-maps-overlay],
  [data-maps-frame][data-state='ready'] [data-maps-consent],
  [data-maps-frame][data-state='ready'] [data-maps-loading] {
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-maps-frame] iframe,
    [data-maps-frame] [data-maps-overlay],
    [data-maps-frame] [data-maps-consent],
    [data-maps-frame] [data-maps-loading],
    [data-maps-frame] [data-maps-loading-sheen],
    [data-maps-frame] [data-maps-loading-dot] {
      animation: none !important;
      transition-duration: 1ms !important;
    }
  }
</style>

<script is:inline>
  (() => {
    function setupMapsEmbeds() {
      document.querySelectorAll('[data-maps-embed]').forEach((root) => {
        if (!(root instanceof HTMLElement) || root.dataset.bound === 'true') return;
        root.dataset.bound = 'true';

        const frame = root.querySelector('[data-maps-frame]');
        const openConsentBtn = root.querySelector('[data-maps-open-consent]');
        const confirmBtn = root.querySelector('[data-maps-confirm]');
        const cancelBtn = root.querySelector('[data-maps-cancel]');

        if (
          !(frame instanceof HTMLElement) ||
          !(openConsentBtn instanceof HTMLButtonElement) ||
          !(confirmBtn instanceof HTMLButtonElement) ||
          !(cancelBtn instanceof HTMLButtonElement)
        ) return;

        const embedUrl = frame.dataset.embedUrl ?? '';
        /** @type {HTMLIFrameElement | null} */
        let iframe = null;

        function setState(state) {
          frame.dataset.state = state;
          frame.setAttribute('aria-busy', state === 'loading' ? 'true' : 'false');
          const consentEl = frame.querySelector('[data-maps-consent]');
          if (consentEl instanceof HTMLElement) {
            consentEl.setAttribute('aria-hidden', state === 'consent' ? 'false' : 'true');
          }
        }

        function openConsent() {
          if (iframe) return;
          setState('consent');
          confirmBtn.focus();
        }

        function closeConsent() {
          if (iframe) return;
          setState('idle');
          openConsentBtn.focus();
        }

        function injectIframe() {
          if (iframe || !embedUrl) return;
          setState('loading');
          iframe = document.createElement('iframe');
          iframe.src = embedUrl;
          iframe.title = 'EM Fahrzeugaufbereitung – Standort auf Google Maps';
          iframe.loading = 'eager';
          iframe.referrerPolicy = 'strict-origin-when-cross-origin';
          iframe.allow = 'geolocation';
          iframe.setAttribute('sandbox', 'allow-popups allow-scripts allow-same-origin');
          iframe.addEventListener('load', () => setState('ready'), { once: true });
          frame.appendChild(iframe);
        }

        openConsentBtn.addEventListener('click', openConsent);
        confirmBtn.addEventListener('click', injectIframe);
        cancelBtn.addEventListener('click', closeConsent);

        frame.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && frame.dataset.state === 'consent') {
            event.preventDefault();
            closeConsent();
          }
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupMapsEmbeds);
    } else {
      setupMapsEmbeds();
    }
  })();
</script>
