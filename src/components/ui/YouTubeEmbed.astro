---
import { uiText } from '@/data/site';
import { getThumbnailPath } from '@/lib/youtube';

interface Props {
  id: string;
  title: string;
  orientation?: 'portrait' | 'landscape';
}

const { id, title, orientation = 'portrait' } = Astro.props;
const thumbnail = getThumbnailPath(id);
const ratioClass = orientation === 'portrait' ? 'aspect-[9/16]' : 'aspect-video';
const previewAlt = `Vorschau für ${title}`;
---

<div class="overflow-hidden rounded-[calc(var(--radius-card)+0.25rem)] border border-[var(--color-border)] bg-[linear-gradient(180deg,rgba(24,29,26,1),rgba(10,12,11,1))] shadow-[var(--shadow-card)]" data-youtube-embed>
  <div class={`relative ${ratioClass} overflow-hidden bg-[radial-gradient(circle_at_top,rgba(91,194,54,0.22),transparent_38%),linear-gradient(180deg,rgba(17,21,19,1),rgba(10,12,11,1))]`} data-youtube-frame>
    <img
      src={thumbnail}
      alt={previewAlt}
      width={540}
      height={960}
      loading="lazy"
      class="absolute inset-0 size-full object-cover opacity-80"
      onerror="this.onerror=null;this.src='/images/yt/placeholder.svg';"
    />
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(10,12,11,0.08),rgba(10,12,11,0.8))]"></div>
    <div class="absolute inset-0 flex flex-col justify-between p-5">
      <div class="flex items-start justify-between gap-3">
        <span class="inline-flex rounded-full border border-[rgba(255,255,255,0.12)] bg-[rgba(10,12,11,0.68)] px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[var(--color-green)]">
          {uiText.youtube.badge}
        </span>
        <span class="rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(10,12,11,0.5)] px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
          {uiText.youtube.privacyBadge}
        </span>
      </div>

      <div class="space-y-4">
        <button
          type="button"
          class="focus-ring inline-flex items-center gap-3 rounded-full border border-[rgba(116,224,74,0.35)] bg-[rgba(10,12,11,0.82)] px-5 py-3 text-sm font-semibold text-[var(--color-text)] shadow-[0_0_24px_rgba(91,194,54,0.2)] transition hover:bg-[rgba(12,15,13,0.96)]"
          data-youtube-trigger
          data-video-id={id}
          data-video-title={title}
          aria-label={`${uiText.youtube.loadLabel}: ${title}`}
        >
          <span class="inline-flex size-10 items-center justify-center rounded-full bg-[var(--color-green)] text-[var(--color-bg)]">
            <svg aria-hidden="true" viewBox="0 0 24 24" class="size-5" fill="currentColor">
              <path d="m10 8 7 4-7 4V8Z" />
            </svg>
          </span>
          {uiText.youtube.loadLabel}
        </button>

        <div class="space-y-2">
          <p class="font-[family-name:var(--font-display)] text-[clamp(1.25rem,3vw,1.75rem)] uppercase leading-none tracking-tight text-[var(--color-text)]">
            {title}
          </p>
          <p class="text-sm leading-6 text-[var(--color-text-muted)]">{uiText.youtube.privacyNotice}</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-youtube-embed]').forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.bound === 'true') return;
      root.dataset.bound = 'true';

      const frame = root.querySelector('[data-youtube-frame]');
      const trigger = root.querySelector('[data-youtube-trigger]');
      if (!(frame instanceof HTMLElement) || !(trigger instanceof HTMLButtonElement)) return;

      trigger.addEventListener('click', () => {
        const videoId = trigger.dataset.videoId ?? '';
        const videoTitle = trigger.dataset.videoTitle ?? '';
        const isPortrait = frame.classList.contains('aspect-[9/16]');
        const iframe = document.createElement('iframe');
        const params = isPortrait
          ? `autoplay=1&rel=0&modestbranding=1&loop=1&playlist=${videoId}`
          : `autoplay=1&rel=0&modestbranding=1`;
        iframe.src = `https://www.youtube-nocookie.com/embed/${videoId}?${params}`;
        iframe.title = videoTitle;
        iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
        iframe.allowFullscreen = true;
        iframe.loading = 'lazy';
        iframe.referrerPolicy = 'strict-origin-when-cross-origin';
        iframe.className = 'absolute inset-0 size-full border-0';
        frame.replaceChildren(iframe);
      });
    });
  })();
</script>
