---
interface Props {
  eyebrow: string;
  title: string;
  id?: string;
}

const { eyebrow, title, id } = Astro.props;
---

<div class="max-w-3xl space-y-4">
  <p class="text-eyebrow font-semibold uppercase tracking-[0.22em] text-[var(--color-green)]">{eyebrow}</p>
  <h2 id={id} class="font-[family-name:var(--font-display)] text-h2 uppercase tracking-tight text-[var(--color-text)]">
    {title}
  </h2>
  <span class="section-divider mt-6"></span>
  <slot />
</div>
