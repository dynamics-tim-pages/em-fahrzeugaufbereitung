---
interface Props {
  variant?: 'primary' | 'ghost' | 'link';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  target?: string;
  rel?: string;
  ariaLabel?: string;
}

const {
  variant = 'primary',
  href,
  class: className = '',
  type = 'button',
  target,
  rel,
  ariaLabel,
} = Astro.props;

const baseClass = 'focus-ring inline-flex items-center justify-center gap-2 whitespace-nowrap transition duration-200';
const variantClass = {
  primary:
    'rounded-[var(--radius-btn)] border border-transparent bg-[var(--color-green)] px-5 py-3 text-sm font-semibold text-[var(--color-bg)] shadow-[0_0_28px_rgba(91,194,54,0.22)] hover:-translate-y-0.5 hover:bg-[var(--color-green-bright)]',
  ghost:
    'rounded-[var(--radius-btn)] border border-[var(--color-green)] px-5 py-3 text-sm font-semibold text-[var(--color-green)] hover:-translate-y-0.5 hover:bg-[rgba(91,194,54,0.08)]',
  link:
    'rounded-none px-0 py-0 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-green)] hover:text-[var(--color-green-bright)]',
}[variant];

const sharedClass = `${baseClass} ${variantClass} ${className}`.trim();
const resolvedRel = rel ?? (target === '_blank' ? 'noreferrer' : undefined);
---

{href ? (
  <a href={href} target={target} rel={resolvedRel} aria-label={ariaLabel} class={sharedClass}>
    <slot />
    {variant === 'link' && (
      <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M5 12h14" stroke-linecap="round" />
        <path d="m12 5 7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}
  </a>
) : (
  <button type={type} aria-label={ariaLabel} class={sharedClass}>
    <slot />
    {variant === 'link' && (
      <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M5 12h14" stroke-linecap="round" />
        <path d="m12 5 7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    )}
  </button>
)}
