---
import { galleryLabels } from '@/data/gallery';
import { sectionContent } from '@/data/site';
---

<dialog
  data-gallery-lightbox
  aria-labelledby="gallery-lightbox-title"
  aria-describedby="gallery-lightbox-caption"
  style="--lightbox-pad-top:max(0.75rem,env(safe-area-inset-top));--lightbox-pad-right:max(0.75rem,env(safe-area-inset-right));--lightbox-pad-bottom:max(0.75rem,env(safe-area-inset-bottom));--lightbox-pad-left:max(0.75rem,env(safe-area-inset-left));padding:var(--lightbox-pad-top) var(--lightbox-pad-right) var(--lightbox-pad-bottom) var(--lightbox-pad-left);"
  class="fixed inset-0 m-0 h-dvh w-full max-h-none max-w-none items-center justify-center overflow-y-auto overflow-x-hidden border-0 bg-transparent p-0 text-[var(--color-text)] shadow-none backdrop:bg-[rgba(4,6,5,0.88)] backdrop:backdrop-blur-md"
>
  <div class="relative w-[min(100%,74rem)] max-h-[calc(100dvh-var(--lightbox-pad-top)-var(--lightbox-pad-bottom))] overflow-y-auto rounded-[calc(var(--radius-card)+0.75rem)] border border-[rgba(255,255,255,0.08)] bg-[linear-gradient(180deg,rgba(17,21,19,0.98),rgba(10,12,11,1))] shadow-[0_36px_100px_-24px_rgba(0,0,0,0.84)]">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(91,194,54,0.14),transparent_34%),linear-gradient(180deg,rgba(255,255,255,0.02),transparent_30%,rgba(0,0,0,0.16))]"></div>
    <div class="pointer-events-none absolute inset-0 hex-pattern opacity-45"></div>

    <div class="relative flex items-start justify-between gap-4 border-b border-[rgba(255,255,255,0.08)] px-4 py-4 sm:px-6 sm:py-5">
      <div class="min-w-0 space-y-2 pr-4">
        <p class="text-eyebrow font-semibold uppercase tracking-[0.22em] text-[var(--color-green)]">{sectionContent.gallery.eyebrow}</p>
        <p class="text-sm leading-6 text-[var(--color-text-muted)]">
          {galleryLabels.before} / {galleryLabels.after}
        </p>
      </div>

      <button
        type="button"
        class="focus-ring inline-flex size-11 shrink-0 items-center justify-center rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(10,12,11,0.72)] text-[var(--color-text-muted)] backdrop-blur-md transition duration-200 hover:-translate-y-0.5 hover:border-[rgba(116,224,74,0.32)] hover:text-[var(--color-text)]"
        data-lightbox-close
        aria-label={galleryLabels.close}
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M6 6 18 18M18 6 6 18" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <div class="relative p-3 sm:p-4 lg:p-5">
      <div class="relative overflow-hidden rounded-[calc(var(--radius-card)+0.35rem)] border border-[rgba(255,255,255,0.08)] bg-[linear-gradient(160deg,rgba(17,21,19,0.78),rgba(10,12,11,0.98))]">
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.06),transparent_28%),radial-gradient(circle_at_top_right,rgba(91,194,54,0.18),transparent_36%),linear-gradient(180deg,rgba(10,12,11,0.08),rgba(10,12,11,0.78))]"></div>
        <div class="pointer-events-none absolute inset-0 hidden bg-[linear-gradient(90deg,rgba(255,255,255,0.015)_0%,rgba(255,255,255,0.015)_49.8%,rgba(255,255,255,0.045)_50%,rgba(255,255,255,0.015)_50.2%,rgba(91,194,54,0.05)_100%)] min-[420px]:block"></div>
        <div class="pointer-events-none absolute inset-0 hex-pattern opacity-65"></div>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-[linear-gradient(180deg,transparent,rgba(10,12,11,0.86))]"></div>

        <div class="relative z-[1] grid min-h-[20rem] min-[420px]:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)] lg:min-h-[32rem]">
          <div class="flex flex-col justify-between gap-8 px-4 pb-5 pt-4 sm:px-6 sm:pb-6 sm:pt-6 lg:px-8 lg:pb-8 lg:pt-8">
            <span
              data-lightbox-before
              class="inline-flex w-fit items-center gap-2 rounded-full border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.04)] px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-muted)] backdrop-blur-sm"
            ></span>

            <div class="max-w-xl space-y-4">
              <h3
                id="gallery-lightbox-title"
                data-lightbox-title
                class="font-[family-name:var(--font-display)] text-[clamp(2.4rem,10vw,4.75rem)] uppercase leading-[0.9] tracking-tight text-[var(--color-text)]"
              ></h3>
              <p
                id="gallery-lightbox-caption"
                data-lightbox-caption
                class="max-w-xl text-sm leading-7 text-[var(--color-text-muted)]"
              ></p>
            </div>
          </div>

          <div class="flex flex-col justify-between gap-8 border-[rgba(255,255,255,0.08)] px-4 pb-5 pt-4 sm:px-6 sm:pb-6 sm:pt-6 min-[420px]:border-l lg:px-8 lg:pb-8 lg:pt-8">
            <div class="flex justify-start min-[420px]:justify-end">
              <span
                data-lightbox-after
                class="inline-flex w-fit items-center gap-2 rounded-full border border-[rgba(116,224,74,0.32)] bg-[rgba(91,194,54,0.10)] px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--color-green)] shadow-[0_0_24px_rgba(91,194,54,0.14)] backdrop-blur-sm"
              ></span>
            </div>

            <div class="space-y-3 min-[420px]:text-right">
              <p data-lightbox-entry class="text-[11px] font-semibold uppercase tracking-[0.22em] text-[var(--color-text-faint)]">
                {galleryLabels.entry}
              </p>
              <p
                data-lightbox-meta
                class="font-[family-name:var(--font-display)] text-[clamp(1.25rem,4vw,1.75rem)] uppercase leading-none tracking-[0.04em] text-[var(--color-text)]"
              ></p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="relative flex justify-start border-t border-[rgba(255,255,255,0.08)] px-4 py-4 sm:px-6 sm:py-5">
      <button
        type="button"
        class="focus-ring inline-flex items-center gap-2 rounded-full border border-[rgba(116,224,74,0.24)] bg-[rgba(91,194,54,0.08)] px-4 py-2.5 text-sm font-semibold text-[var(--color-green)] transition duration-200 hover:-translate-y-0.5 hover:border-[rgba(116,224,74,0.42)] hover:bg-[rgba(91,194,54,0.12)] sm:ml-auto"
        data-lightbox-close
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M19 12H5" stroke-linecap="round" />
          <path d="m12 19-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        {galleryLabels.close}
      </button>
    </div>
  </div>
</dialog>

<style>
  dialog[data-gallery-lightbox][open] {
    display: flex;
  }
</style>

<script is:inline>
  (() => {
    const dialog = document.querySelector('[data-gallery-lightbox]');
    if (!(dialog instanceof HTMLDialogElement) || dialog.dataset.bound === 'true') return;
    dialog.dataset.bound = 'true';

    const title = dialog.querySelector('[data-lightbox-title]');
    const caption = dialog.querySelector('[data-lightbox-caption]');
    const meta = dialog.querySelector('[data-lightbox-meta]');
    const entry = dialog.querySelector('[data-lightbox-entry]');
    const before = dialog.querySelector('[data-lightbox-before]');
    const after = dialog.querySelector('[data-lightbox-after]');
    const closeButtons = [...dialog.querySelectorAll('[data-lightbox-close]')];
    const defaultTitle = title?.textContent?.trim() ?? '';
    const defaultCaption = caption?.textContent?.trim() ?? '';
    const defaultMeta = meta?.textContent?.trim() ?? '';
    const defaultEntry = entry?.textContent?.trim() ?? '';
    let lastFocused = null;

    const focusableElements = () =>
      [...dialog.querySelectorAll('button,[href],[tabindex]:not([tabindex="-1"])')].filter(
        (element) => !element.hasAttribute('disabled'),
      );

    const close = () => {
      if (dialog.open) {
        dialog.close();
      }
      document.body.classList.remove('overflow-hidden');
      if (lastFocused instanceof HTMLElement) {
        lastFocused.focus();
      }
    };

    const open = (trigger) => {
      lastFocused = trigger;
      const itemTitle = trigger.dataset.title ?? '';
      const itemCaption = trigger.dataset.caption ?? '';
      const itemMeta = trigger.dataset.meta ?? '';
      const itemEntry = trigger.dataset.entry ?? '';
      const beforeLabel = trigger.dataset.before ?? '';
      const afterLabel = trigger.dataset.after ?? '';

      if (title) title.textContent = itemTitle || defaultTitle;
      if (caption) caption.textContent = itemCaption || defaultCaption;
      if (meta) meta.textContent = itemMeta || defaultMeta;
      if (entry) entry.textContent = itemEntry || defaultEntry;
      if (before) before.textContent = beforeLabel;
      if (after) after.textContent = afterLabel;

      if (!dialog.open) {
        dialog.showModal();
      }

      document.body.classList.add('overflow-hidden');
      requestAnimationFrame(() => {
        const firstButton = closeButtons[0];
        if (firstButton instanceof HTMLElement) {
          firstButton.focus();
        }
      });
    };

    document.querySelectorAll('[data-lightbox-trigger]').forEach((trigger) => {
      if (!(trigger instanceof HTMLButtonElement) || trigger.dataset.bound === 'true') return;
      trigger.dataset.bound = 'true';
      trigger.addEventListener('click', () => open(trigger));
    });

    closeButtons.forEach((button) => button.addEventListener('click', close));

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        close();
      }
    });

    dialog.addEventListener('cancel', (event) => {
      event.preventDefault();
      close();
    });

    dialog.addEventListener('keydown', (event) => {
      if (event.key !== 'Tab') return;

      const focusable = focusableElements();
      if (!focusable.length) return;

      const first = focusable[0];
      const last = focusable[focusable.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });
  })();
</script>
