---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  intro?: string;
}

const { id, eyebrow, title, intro } = Astro.props;
---

<section id={id} class="px-6 py-16 md:px-10 md:py-20">
  <div class="mx-auto flex max-w-6xl flex-col gap-6">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">
        {eyebrow}
      </p>
    )}
    {title && <h2 class="max-w-3xl text-3xl font-semibold tracking-tight text-slate-950 md:text-4xl">{title}</h2>}
    {intro && <p class="max-w-2xl text-base leading-7 text-slate-600 md:text-lg">{intro}</p>}
    <slot />
  </div>
</section>
