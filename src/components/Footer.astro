---
import { brand, legalLinks, socialLinks, uiText } from '@/data/site';

const icons: Record<string, string> = {
  Facebook: '<path d="M14 8h3V4h-3c-2.8 0-5 2.2-5 5v3H6v4h3v4h4v-4h3.2l.8-4H13V9c0-.6.4-1 1-1Z" stroke-linejoin="round"/>',
  Instagram: '<rect x="4" y="4" width="16" height="16" rx="4" /><circle cx="12" cy="12" r="3.5" /><circle cx="17.2" cy="6.8" r=".8" fill="currentColor" stroke="none"/>',
  TikTok: '<path d="M14 4c.3 1.8 1.4 3.4 3 4.2" stroke-linecap="round"/><path d="M14 4v9.1a3.1 3.1 0 1 1-2.4-3" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 7.4c.8.8 1.8 1.4 2.9 1.7" stroke-linecap="round"/>',
  WhatsApp: '<path d="M12 20a8 8 0 1 0-4.3-1.3L4 20l1.4-3.5A8 8 0 0 0 12 20Z" stroke-linejoin="round"/><path d="M9.2 9.1c.2-.5.4-.5.7-.5h.6c.2 0 .4 0 .5.3l.8 1.8c.1.2.1.4 0 .6l-.5.6c-.1.1-.1.3 0 .4.4.7 1.1 1.4 1.8 1.8.1.1.3.1.4 0l.6-.5c.2-.1.4-.1.6 0l1.8.8c.2.1.3.3.3.5v.6c0 .3 0 .5-.5.7-.4.2-1 .3-1.5.2-2.6-.5-5.2-3.1-5.7-5.7-.1-.5 0-1.1.2-1.5Z" stroke-linejoin="round"/>'
};
---

<footer class="border-t border-[rgba(255,255,255,0.06)] py-10 pb-28 md:pb-10">
  <div class="mx-auto grid max-w-[var(--container-max)] gap-10 px-[var(--gutter)] lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
    <div class="space-y-6">
      <div class="space-y-3">
        <div class="inline-flex items-center gap-3 rounded-full border border-[var(--color-border)] bg-[rgba(17,21,19,0.9)] px-4 py-2 shadow-[0_0_20px_rgba(91,194,54,0.12)]">
          <span class="font-[family-name:var(--font-display)] text-2xl uppercase leading-none text-[var(--color-text)]">
            {brand.monogramLeading}
          </span>
          <span class="font-[family-name:var(--font-display)] text-2xl uppercase leading-none text-[var(--color-green)]">
            {brand.monogramAccent}
          </span>
          <span class="font-[family-name:var(--font-display)] text-xl uppercase tracking-tight text-[var(--color-text)]">
            {brand.wordmark}
          </span>
        </div>
        <p class="max-w-xl text-body text-[var(--color-text-muted)]">{uiText.footer.claim}</p>
      </div>

      <div class="flex flex-wrap gap-3">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noreferrer"
            aria-label={social.label}
            class="focus-ring inline-flex size-12 items-center justify-center rounded-full border border-[var(--color-border)] bg-[rgba(17,21,19,0.86)] text-[var(--color-text-muted)] transition hover:border-[rgba(116,224,74,0.3)] hover:text-[var(--color-green)]"
          >
            <svg aria-hidden="true" viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="1.7" set:html={icons[social.label]}></svg>
          </a>
        ))}
      </div>
    </div>

    <div class="space-y-5 lg:text-right">
      <nav class="flex flex-wrap gap-4 lg:justify-end" aria-label={uiText.footer.legalNavLabel}>
        {legalLinks.map((link) => (
          <a href={link.href} class="focus-ring rounded-sm text-sm font-medium text-[var(--color-text-muted)] transition hover:text-[var(--color-green)]">
            {link.label}
          </a>
        ))}
      </nav>
      <p class="text-sm text-[var(--color-text-faint)]">{uiText.footer.copyright}</p>
    </div>
  </div>
</footer>
