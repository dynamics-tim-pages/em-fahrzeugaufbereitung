---
import Lightbox from '@/components/ui/Lightbox.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { gallery, galleryLabels } from '@/data/gallery';
import { sectionContent } from '@/data/site';
---

<section id="galerie" class="scroll-mt-28 py-[var(--space-section)]" aria-labelledby="gallery-title">
  <div class="mx-auto max-w-[var(--container-max)] space-y-12 px-[var(--gutter)]">
    <SectionHeading id="gallery-title" eyebrow={sectionContent.gallery.eyebrow} title={sectionContent.gallery.title}>
      <p class="mt-6 max-w-2xl text-body text-[var(--color-text-muted)]">{sectionContent.gallery.intro}</p>
    </SectionHeading>

    <div class="grid gap-[var(--grid-gap)] sm:grid-cols-2 xl:grid-cols-3">
      {gallery.map((item) => (
        <button
          type="button"
          class="focus-ring reveal group relative overflow-hidden rounded-[calc(var(--radius-card)+0.25rem)] border border-[var(--color-border)] bg-[linear-gradient(180deg,rgba(24,29,26,0.98),rgba(10,12,11,1))] text-left shadow-[var(--shadow-card)] transition duration-300 hover:-translate-y-1 hover:border-[rgba(116,224,74,0.34)]"
          data-lightbox-trigger
          data-title={item.title}
          data-caption={item.caption}
          data-meta={item.meta}
          data-entry={item.entryLabel}
          data-before={galleryLabels.before}
          data-after={galleryLabels.after}
          aria-label={`${galleryLabels.open}: ${item.title}`}
        >
          <div class="relative aspect-[4/5] overflow-hidden p-4 sm:p-5">
            <div class="absolute inset-0 hex-pattern opacity-60 transition duration-300 group-hover:scale-105"></div>
            <div class="relative grid h-full gap-3 sm:grid-cols-2">
              <div class="rounded-[var(--radius-card)] border border-[rgba(255,255,255,0.08)] bg-[rgba(255,255,255,0.03)] p-4">
                <span class="inline-flex rounded-full border border-[var(--color-border)] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-text-muted)]">
                  {galleryLabels.before}
                </span>
              </div>
              <div class="rounded-[var(--radius-card)] border border-[rgba(116,224,74,0.3)] bg-[rgba(91,194,54,0.08)] p-4 shadow-[0_0_24px_rgba(91,194,54,0.12)]">
                <span class="inline-flex rounded-full border border-[rgba(116,224,74,0.34)] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-[var(--color-green)]">
                  {galleryLabels.after}
                </span>
              </div>
            </div>
            <div class="absolute inset-x-4 bottom-4 sm:inset-x-5 sm:bottom-5">
              <p class="font-[family-name:var(--font-display)] text-[clamp(1.5rem,3vw,2rem)] uppercase leading-none tracking-tight text-[var(--color-text)]">
                {item.title}
              </p>
            </div>
          </div>
        </button>
      ))}
    </div>
  </div>

  <Lightbox />
</section>
